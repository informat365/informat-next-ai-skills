{
	"type": "function",
	"function": {
		"name": "_survey_create_module",
		"description": "创建问卷调查模块。",
		"parameters": {
			"type": "object",
			"properties": {
				"id": {
					"type": "string",
					"description": "模块ID（使用驼峰命名，且在系统内唯一，不得与现有模块重复）。"
				},
				"name": {
					"type": "string",
					"description": "模块名称。"
				},
				"parentId": {
					"type": "string",
					"description": "模块分组ID，工具_query_app_define_designer可以获取到模块分组定义列表"
				}
			},
			"required": ["id", "name"]
		}
	}
}
