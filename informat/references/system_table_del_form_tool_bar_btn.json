{
  "type": "function",
  "function": {
    "name": "_table_del_form_tool_bar_btn",
    "description": "Delete a form toolbar button of the data table. Must call _table_list_form_tool_bar_btn first to get button ID.",
    "parameters": {
      "type": "object",
      "properties": {
        "tableId": {
          "type": "string",
          "description": "Table ID (must exist)."
        },
        "buttonId": {
          "type": "string",
          "description": "Button ID to delete (obtained via _table_list_form_tool_bar_btn)."
        }
      },
      "required": ["tableId", "buttonId"]
    }
  }
}
